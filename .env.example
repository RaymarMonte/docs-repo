# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.

# --- Supabase ---
# Project URL and anon (publishable) key from your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Vercel AI SDK provider ---
# API key for your chosen model provider (this project defaults to Anthropic).
ANTHROPIC_API_KEY=
